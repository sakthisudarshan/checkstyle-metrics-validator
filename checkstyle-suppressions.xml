<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Framework/infrastructure code is not part of the scoring audit -->
    <suppress checks=".*"
              files="[\\/]com[\\/]testable[\\/]checkstyle[\\/].*\.java"/>

    <!-- Validator corpus is audited in rule-coverage, not the Maven scoring path -->
    <suppress checks=".*"
              files="[\\/]com[\\/]testable[\\/]validators[\\/].*\.java"/>

    <!-- Violation demos are exercised via rule-coverage; only CleanDemo is scored -->
    <suppress checks=".*"
              files="[\\/]com[\\/]testable[\\/]demo[\\/](?!CleanDemo)[^\\/]+\.java"/>

    <!-- Test samples and coverage fixtures are not part of the scoring audit -->
    <suppress checks=".*"
              files="[\\/]samples[\\/].*\.java"/>
    <suppress checks=".*"
              files="[\\/]coverage[\\/].*\.java"/>

    <suppress checks="LineLength"
              files="SuppressedViolationSample\.java"
              lines="12"/>
</suppressions>
